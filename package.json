{
  "name": "ahdn",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "types": "supabase gen types typescript --project-id lzgryhrztslevnuajiqm --schema public > src/lib/database.types.ts",
    "script": "bash -c 'npm exec tsx $1'",
    "schema:remote": "supabase db dump --schema public -f supabase/schema.sql",
    "schema:local": "supabase db dump --schema public --local -f supabase/schema.sql",
    "data:remote": "supabase db dump --linked --schema public --data-only -f supabase/data.sql",
    "data:local": "supabase db dump --linked --schema public --local --data-only -f supabase/data.sql",
    "db:reset": "bash ./scripts/db_reset.sh supabase"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.95.3",
    "@tailwindcss/vite": "^4.1.18",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "embla-carousel-react": "^8.6.0",
    "execa": "^9.6.1",
    "ffmpeg-static": "^5.3.0",
    "lucide-react": "^0.563.0",
    "mime-types": "^3.0.2",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-h5-audio-player": "^3.10.1",
    "react-helmet-async": "^3.0.0",
    "react-router": "^7.13.0",
    "sharp": "^0.34.5",
    "swiper": "^12.1.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/facebook-js-sdk": "^3.3.12",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^24.10.12",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "shadcn": "^3.8.4",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vite-plugin-svgr": "^4.5.0"
  }
