# Optional overrides for `make test-*`.
# These are auto-loaded only by the test orchestrator targets in the Makefile.

WORKER_SHARED_SECRET="local-worker-shared-secret"
TEST_SUPABASE_URL="http://127.0.0.1:54321"
TEST_SUPABASE_ANON_KEY="optional-local-anon-token"
TEST_SUPABASE_SERVICE_ROLE_KEY="optional-local-service-role-token"
TEST_SUPABASE_JWT_SECRET="optional-local-jwt-secret"
